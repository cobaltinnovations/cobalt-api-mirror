#!/bin/bash

set -e

echo "Bootstrapping Cobalt API for local testing..."

./bootstrap

if [ -d "sql/local" ]; then
  for script in sql/local/*.sql; do
    if [ -f "$script" ]; then
      echo "Applying local data script: $script"
      PGPASSWORD=password psql -U cobalt -h localhost -p 5501 -d cobalt -f "$script"
    fi
  done
fi

echo "Local bootstrap complete."
